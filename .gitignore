# Lokale Datenbanken (regenerierbar / sensibel)
.archiv/*
!.archiv/projekte_konfiguration.json
!.archiv/agent_cluster.json
.palace/
.credentials/
credentials.db
*.sqlite
*.sqlite-journal
*.sqlite-shm
*.sqlite-wal

# Obsidian Multi-Device-Konflikte
Vault/.obsidian/workspace*
Vault/.obsidian/cache/
Vault/.obsidian/workspace.json

# Plugin-State mit moeglichen Secrets (API-Keys, Tokens, Cert-Private-Keys)
# WICHTIG: Local REST API speichert apiKey + RSA privateKey hier!
Vault/.obsidian/plugins/*/data.json

# claudian Plugin-State (User-Settings, persoenlich)
Vault/.claudian/

# Logs und Temporäres
Logs/
*.log
*.tmp

# Geheimes (Sicherheit)
*.env
*credentials*.json
*token*
*secret*

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# OS
Thumbs.db
.DS_Store
desktop.ini
